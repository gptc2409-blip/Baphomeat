<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BAPHOM | Luxury Archive</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        .reveal { opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out; }
        .reveal.active { opacity: 1; transform: translateY(0); }
        .modal { display: none; position: fixed; inset: 0; background: white; z-index: 100; overflow-y: auto; }
        .modal.active { display: block; }
        /* Estética de Luxo: Espaçamento de letras */
        .tracking-extreme { tracking: 0.5em; }
    </style>
</head>
<body class="bg-white text-black selection:bg-black selection:text-white">

    <div id="mobileMenu" class="fixed inset-0 bg-white z-[60] flex flex-col p-8 transition-transform duration-500 translate-x-full">
        <div class="flex justify-end">
            <button onclick="toggleMenu()" class="text-sm font-bold tracking-widest uppercase">Fechar [X]</button>
        </div>
        <nav class="flex flex-col gap-8 mt-20 text-5xl font-black tracking-tighter">
            <a href="#shop" onclick="toggleMenu()">SHOP</a>
            <a href="#campaign" onclick="toggleMenu()">COLLECTIONS</a>
            <a href="#footer" onclick="toggleMenu()">CONTACT</a>
        </nav>
    </div>

    <nav class="fixed w-full z-50 px-6 py-6 flex justify-between items-center bg-white/80 backdrop-blur-sm border-b border-gray-100">
        <div class="flex-1 lg:hidden">
            <button onclick="toggleMenu()" class="font-bold text-[10px] tracking-[0.2em]">MENU</button>
        </div>
        
        <div class="hidden lg:flex flex-1 gap-8 text-[10px] tracking-[0.3em] font-bold">
            <a href="#shop" class="hover:opacity-50">SHOP</a>
            <a href="#campaign" class="hover:opacity-50">ARCHIVE</a>
        </div>

        <div class="text-2xl font-black tracking-tighter cursor-pointer uppercase" onclick="window.scrollTo(0,0)">
            BAPHOM<span class="font-light italic text-gray-400"> STUDIO</span>
        </div>

        <div class="flex flex-1 justify-end gap-6 text-[10px] font-bold tracking-[0.3em]">
            <span>CART (0)</span>
        </div>
    </nav>

    <section class="relative h-screen flex items-center justify-center bg-black overflow-hidden">
        <img src="https://images.unsplash.com/photo-1550639525-c97d455acf70?auto=format&fit=crop&q=80&w=1600" class="absolute inset-0 w-full h-full object-cover opacity-60 scale-105 animate-pulse">
        <div class="relative z-10 text-center text-white p-4">
            <p class="text-[10px] tracking-[0.8em] mb-4 uppercase font-bold opacity-80">BAPHOM ARCHIVE 2026</p>
            <h1 class="text-6xl md:text-[110px] font-black tracking-tighter leading-none mb-10">PURE AVANT-GARDE</h1>
            <a href="#shop" class="bg-white text-black px-12 py-5 text-[10px] font-bold tracking-[0.4em] hover:bg-zinc-200 transition-all">SHOP COLLECTION</a>
        </div>
    </section>

    <main id="shop" class="max-w-[1400px] mx-auto px-6 py-32">
        <div class="flex justify-between items-center mb-16 reveal">
            <h2 class="text-xs font-bold tracking-[0.5em] uppercase">Season Essentials</h2>
            <span class="text-[9px] text-gray-400">SORT BY: RELEVANCE</span>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16">
            <div class="group cursor-pointer reveal" onclick="openProduct('Cyber Puffer Jacket', '€ 1.450', 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?auto=format&fit=crop&q=80&w=800')">
                <div class="aspect-[3/4] overflow-hidden bg-zinc-100 mb-6">
                    <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105">
                </div>
                <div class="flex flex-col gap-2 font-bold text-[11px] tracking-widest">
                    <h3 class="uppercase">Cyber Puffer Jacket</h3>
                    <span class="text-gray-400">€ 1.450</span>
                </div>
            </div>

            <div class="group cursor-pointer reveal" onclick="openProduct('Monolith Cargo Pants', '€ 920', 'https://images.unsplash.com/photo-1594633312681-425c7b97ccd1?auto=format&fit=crop&q=80&w=800')">
                <div class="aspect-[3/4] overflow-hidden bg-zinc-100 mb-6">
                    <img src="https://images.unsplash.com/photo-1594633312681-425c7b97ccd1?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105">
                </div>
                <div class="flex flex-col gap-2 font-bold text-[11px] tracking-widest">
                    <h3 class="uppercase">Monolith Cargo Pants</h3>
                    <span class="text-gray-400">€ 920</span>
                </div>
            </div>

            <div class="group cursor-pointer reveal" onclick="openProduct('Void Boots X1', '€ 1.100', 'https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?auto=format&fit=crop&q=80&w=800')">
                <div class="aspect-[3/4] overflow-hidden bg-zinc-100 mb-6">
                    <img src="https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105">
                </div>
                <div class="flex flex-col gap-2 font-bold text-[11px] tracking-widest">
                    <h3 class="uppercase">Void Boots X1</h3>
                    <span class="text-gray-400">€ 1.100</span>
                </div>
            </div>
        </div>
    </main>

    <footer id="footer" class="bg-white border-t border-gray-100 px-6 py-24 text-center">
        <h2 class="text-4xl font-black tracking-tighter mb-12 uppercase">BAPHOM</h2>
        <div class="flex flex-col md:flex-row justify-center gap-12 text-[10px] font-bold tracking-[0.3em] text-gray-400">
            <a href="#" class="hover:text-black">INSTAGRAM</a>
            <a href="#" class="hover:text-black">PRIVACY POLICY</a>
            <a href="#" class="hover:text-black">SUPPORT</a>
            <a href="#" class="hover:text-black">WHATSAPP</a>
        </div>
        <p class="mt-20 text-[8px] tracking-[0.5em] text-gray-300">© 2026 BAPHOM ARCHIVE. ALL RIGHTS RESERVED.</p>
    </footer>

    <div id="productModal" class="modal p-6 md:p-20">
        <button onclick="closeProduct()" class="fixed top-8 right-8 font-bold text-[10px] tracking-widest z-[110] bg-black text-white px-6 py-3 uppercase">Close [X]</button>
        
        <div class="flex flex-col md:flex-row gap-16 max-w-[1200px] mx-auto mt-12">
            <div class="flex-1">
                <img id="modalImg" src="" class="w-full aspect-[3/4] object-cover bg-zinc-50 grayscale hover:grayscale-0 transition-all duration-700">
            </div>
            <div class="flex-1 flex flex-col justify-center">
                <p class="text-[10px] tracking-[0.5em] text-gray-400 mb-4 uppercase">Baphom Studio Item</p>
                <h2 id="modalTitle" class="text-5xl md:text-7xl font-black tracking-tighter mb-6 uppercase"></h2>
                <p id="modalPrice" class="text-2xl mb-10 font-light"></p>
                <div class="h-[1px] w-full bg-gray-100 mb-10"></div>
                <p class="text-[10px] leading-loose tracking-widest mb-12 text-gray-500 uppercase">
                    Peça de curadoria limitada. Design focado em silhueta e volume. Cada item faz parte do manifesto de arquivo da BAPHOM.
                </p>
                <a href="https://wa.me/SEUNUMERO" target="_blank" class="bg-black text-white text-center py-6 text-[10px] font-bold tracking-[0.5em] hover:bg-zinc-800 transition-all uppercase">
                    Check Availability
                </a>
            </div>
        </div>
    </div>

    <script>
        function toggleMenu() {
            const menu = document.getElementById('mobileMenu');
            menu.classList.toggle('translate-x-full');
        }

        function openProduct(name, price, img) {
            document.getElementById('modalTitle').innerText = name;
            document.getElementById('modalPrice').innerText = price;
            document.getElementById('modalImg').src = img;
            document.getElementById('productModal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeProduct() {
            document.getElementById('productModal').classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('active');
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
</body>
</html>
